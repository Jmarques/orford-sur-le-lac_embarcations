{
  "permissions": {
    "allow": [
      "Bash(node --test *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(sips *)",
      "Bash(grep * /Users/jeremy/.claude/skills/*)",
      "Read(//Users/jeremy/.claude/skills/**)",
      "Bash(node tmp/*)",
      "Bash(rm -f tmp/*)",
      "Bash(rm -f screenshots/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/verifie-commande.mjs\"",
            "timeout": 10,
            "statusMessage": "Vérifie que la commande reste nue (CLAUDE.md)"
          }
        ]
      }
    ]
  }
}
